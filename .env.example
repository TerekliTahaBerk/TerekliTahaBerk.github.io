# ============================================================
# .env.example — TEMPLATE · safe to commit
# ============================================================
# Copy to .env.local for local dev. Real values go to Vercel via:
#   vercel env add DATABASE_URL production
# ============================================================

# --- Prisma Postgres (Prisma Cloud) ---
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
POSTGRES_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
PRISMA_DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# --- Auth secrets ---
# AUTH_SECRET="generate via: openssl rand -base64 32"

# --- Feature flags ---
NODE_ENV="development"
